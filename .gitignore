# Data and models (large files)
# Patterns are unrooted so they match data/models/reports no matter where they
# live (repo root OR src/graphguard/). This prevents accidentally committing
# generated artifacts under the package tree.
src/graphguard/data/
**/data/raw/*.csv
**/data/processed/*.pt
**/data/processed/*.pkl
**/data/processed/*.json
**/models/*.pt
**/models/*.joblib

# Reports (generated)
**/reports/*.png
**/reports/*.json
**/reports/*.csv
!reports/metrics.json
!reports/model_comparison.csv
!reports/explanation_summary.json
!reports/roc_curves.png
!reports/pr_curves.png

# Logs
*.log
lightning_logs/
wandb/

